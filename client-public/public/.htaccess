<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Jika request adalah file fisik yang ada (CSS, JS, Gambar), sajikan langsung
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # 2. Jika mengakses /tentang, cek apakah file /tentang.html ada
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^(.*)$ $1.html [L]

  # 3. Jika mengakses folder /tentang/, cek apakah ada /tentang/index.html
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_FILENAME}/index.html -f
  RewriteRule ^ - [L]

  # 4. Fallback ke root index.html untuk Single Page Routing jika halaman tidak ditemukan
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [L]
</IfModule>

# Custom ErrorDocument jika 404
ErrorDocument 404 /index.html
